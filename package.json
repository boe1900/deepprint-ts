    "@assistant-ui/react-markdown": "^0.12.3",
    "@hono/node-server": "^2.0.6",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.1.18",
    "ai": "^6.0.77",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.11.8",
    "kysely": "^0.28.11",
    "lucide-react": "^0.563.0",
    "pg": "^8.16.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
