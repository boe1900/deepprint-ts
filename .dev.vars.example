# Better Auth / GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
BETTER_AUTH_SECRET=replace-with-a-long-random-string
# BETTER_AUTH_URL=http://127.0.0.1:8788

# AI provider (optional, only needed if you want a server-side default AI config)
AI_PROVIDER_TYPE=google
AI_API_KEY=your_ai_api_key
AI_MODEL=gemini-flash-latest

# OpenAI-compatible providers only
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_API_MODE=chat

# Compatibility aliases (optional)
# AI_PROVIDER=openai
# GOOGLE_GENERATIVE_AI_API_KEY=

# typst-json-render service
TJR_RENDER_BASE_URL=http://127.0.0.1:8000
# TJR_RENDER_API_KEY=dev-token

# Trial limits (optional)
TRIAL_LIMIT_ENABLED=false
TRIAL_SUCCESSFUL_GENERATIONS_PER_24H=5
TRIAL_SUCCESSFUL_GENERATION_DEDUP_MINUTES=30
# TRIAL_LIMIT_EXEMPT_EMAILS=you@example.com
